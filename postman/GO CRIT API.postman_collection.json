				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"let jsonData = pm.response.json();\r",
									"\r",
									"// ✅ Save access token if present\r",
									"if (jsonData.token) {\r",
									"    pm.environment.set(\"access_token\", jsonData.token);\r",
									"    pm.environment.set(\"refresh_token\", jsonData.refresh_token);\r",
									"    pm.globals.set(\"TOKEN\", jsonData.token);  // use jsonData.token directly\r",
									"    console.log(\"✅ Access token stored:\", jsonData.token);\r",
									"} else {\r",
									"    console.warn(\"⚠️ No token found in response!\", jsonData);\r",
									"}\r",
									"\r",
									"// ✅ Test: Status code is 200\r",
									"pm.test(\"Response status code is 200\", function () {\r",
									"    pm.expect(pm.response.code).to.equal(200);\r",
									"});\r",
									"\r",
									"// ✅ Test: Response has required fields\r",
									"pm.test(\"Response has required fields\", function () {\r",
									"    pm.expect(jsonData).to.be.an('object');\r",
									"    pm.expect(jsonData).to.have.all.keys('email', 'message', 'refresh_token', 'token');\r",
									"});\r",
									"\r",
									"// ✅ Test: Token is non-empty string\r",
									"pm.test(\"Token must be a non-empty string\", function () {\r",
									"    pm.expect(jsonData.token).to.exist.and.to.be.a('string').and.to.have.lengthOf.at.least(1, \"Token should not be empty\");\r",
									"});\r",
									"\r",
									"// ✅ Test: Response time < 200ms\r",
									"pm.test(\"Response time is less than 200ms\", function () {\r",
									"    pm.expect(pm.response.responseTime).to.be.below(200);\r",
									"});\r",
									"\r",
									"// ✅ Test: Response schema and field format\r",
									"pm.test(\"Validate the response schema against the expected structure\", function () {\r",
									"    pm.expect(jsonData).to.be.an('object').that.includes.all.keys('email', 'message', 'refresh_token', 'token');\r",
									"\r",
									"    pm.expect(jsonData.email).to.be.a('string').and.to.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/, \"Email should be in a valid format\");\r",
									"    pm.expect(jsonData.message).to.be.a('string');\r",
									"    pm.expect(jsonData.refresh_token).to.be.a('string');\r",
									"    pm.expect(jsonData.token).to.be.a('string');\r",
									"});\r",
									"\r",
									"// ✅ (Redundant) Test: Request authorized — already covered by 200 check\r",
									"pm.test(\"Request was authorized\", function () {\r",
									"    pm.response.to.have.status(200);\r",
									"});\r",
									""
								],
								"type": "text/javascript",
								"packages": {}
							}
						},
