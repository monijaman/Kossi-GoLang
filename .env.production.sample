# Sample production environment file for gocrit_server
# Copy this to .env.production and fill with real secrets. Do NOT commit .env.production.

# Application.
GO_ENV=production
PORT=8080

# Prefer DATABASE_URL if your provider gives one. Example:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=disable
DATABASE_URL=

# Or provide components (these are used only if DATABASE_URL is empty and your app supports it)
DB_HOST=localhost
DB_PORT=5432
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=kossti
DB_SSLMODE=disable

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret

# Kafka
KAFKA_BROKER=localhost:9092

# AWS / S3 (if used)
S3_BUCKET=kossti
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Optional: other service endpoints
# REDIS_URL=redis://:password@redis-host:6379/0
