# App
GO_ENV=production
PORT=9090

# Railway Production Database - MUST have sslmode=require
# Get actual values from Railway dashboard under your database service
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=

# JWT
JWT_SECRET=

# Kafka
KAFKA_BROKER=

# Server URL (used for image proxy URLs generated server-side)
SERVER_URL=

# AWS S3
S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
